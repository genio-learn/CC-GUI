# Local development override.
#
# By default CC-GUI builds against a pinned claude-commander release (the `git`
# + `tag` dependency in src-tauri/Cargo.toml). To develop against a local
# checkout instead — so edits to claude-commander show up here immediately —
# copy this file to `.cargo/config.toml` (which is gitignored) and put your
# checkout at ../claude-commander (a sibling of this repo).
#
# Cargo then transparently substitutes the local crate for the git dependency,
# with no Cargo.toml change. The local checkout's version must match the pinned
# tag's version, or Cargo ignores the override with a warning.
#
# Since claude-commander v0.24.0 the upstream repo is a workspace; the library
# CC-GUI consumes is the `claude-commander-core` crate, so the override points
# at that crate's directory.
paths = ["../claude-commander/crates/claude-commander-core"]
