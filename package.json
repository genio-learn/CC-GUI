{
  "name": "cc-gui",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-iwft": "playwright test -c playwright-ct.config.ts",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "release": "bash scripts/release.sh",
    "app:build": "tauri build",
    "app:install": "tauri build && rm -rf /Applications/CC-GUI.app && cp -R src-tauri/target/release/bundle/macos/CC-GUI.app /Applications/ && echo 'Installed to /Applications/CC-GUI.app'",
    "prepare": "husky"
  },
  "dependencies": {
    "@shikijs/engine-oniguruma": "^4.2.0",
    "@shikijs/langs": "^4.2.0",
    "@shikijs/themes": "^4.2.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
