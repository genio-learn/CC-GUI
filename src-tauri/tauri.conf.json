{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC-GUI",
  "version": "0.1.4",
  "identifier": "co.genio.cc-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CC-GUI",
        "width": 1280,
        "height": 820,
        "backgroundColor": "#1e1e2e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
